{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch Frontend (Chrome)",
            "request": "launch",
            "type": "chrome",
            "url": "http://localhost:5173",
            "webRoot": "${workspaceFolder}/src"
        },
        {
            "name": "Launch Backend (FastAPI)",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "main:app",
                "--reload",
                "--port",
                "8000"
            ],
            "jinja": true,
            "justMyCode": true,
            "cwd": "${workspaceFolder}/backend"
        }
    ],
    "compounds": [
        {
            "name": "Full Stack Debugging",
            "configurations": ["Launch Backend (FastAPI)", "Launch Frontend (Chrome)"]
        }
    ]
}